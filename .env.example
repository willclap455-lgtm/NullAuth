APP_ENV=production
APP_URL=https://passwords.example.internal
APP_KEY_BASE64=replace-with-32-random-bytes-base64
APP_PEPPER=replace-with-long-random-secret-outside-database
APP_HOTKEY_SEQUENCE=ArrowUp,ArrowUp,ArrowDown,ArrowDown,ArrowLeft,ArrowRight,ArrowLeft,ArrowRight,b,a
APP_SESSION_NAME=nullauth_session
APP_SESSION_IDLE_SECONDS=900
APP_SESSION_ABSOLUTE_SECONDS=28800
APP_ALLOWLIST_CIDRS=

DB_DSN=pgsql:host=127.0.0.1;port=5432;dbname=nullauth
DB_USER=nullauth_app
DB_PASSWORD=replace-with-database-password

MAIL_FROM=nullauth@example.internal
BACKUP_RECIPIENT=
